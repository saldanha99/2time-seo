# ─────────────────────────────────────────────────────
# 2time SEO — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# ─────────────────────────────────────────────────────

# Banco de dados (Neon serverless — crie em neon.tech)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host-direct/db?sslmode=require"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"

# IA — pelo menos um é obrigatório para usar o gerador
GEMINI_API_KEY=""       # https://aistudio.google.com
OPENAI_API_KEY=""       # https://platform.openai.com
ANTHROPIC_API_KEY=""    # https://console.anthropic.com
OPENROUTER_API_KEY=""   # https://openrouter.ai
GROQ_API_KEY=""         # https://console.groq.com
DEEPSEEK_API_KEY=""     # https://platform.deepseek.com

# Indexação (opcionais — configuráveis também pelo painel)
INDEXNOW_KEY=""                    # bing.com/indexnow
GOOGLE_SERVICE_ACCOUNT_JSON=""     # JSON da service account Google

# Site (fallback — configurável também pelo painel Admin > Configurações)
NEXT_PUBLIC_SITE_NAME="2time SEO"
