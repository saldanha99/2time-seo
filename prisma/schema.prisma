// 2time SEO — Schema Prisma
// Stack: Neon (PostgreSQL serverless) + Prisma 5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(ADMIN)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  EDITOR
}

// ── Configurações do projeto ──────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ── Glossário ─────────────────────────────────────────────────────────────────

model GlossaryTerm {
  id           String         @id @default(cuid())
  termo        String
  slug         String         @unique
  letra        String
  nicho        String?
  conteudo     String         @db.Text
  resumo       String?
  seoTitle     String?
  imagem       String?
  publicado    Boolean        @default(false)
  revisado     Boolean        @default(false)
  views        Int            @default(0)
  origem       GlossaryOrigem @default(MANUAL)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([letra, publicado])
  @@index([createdAt])
}

enum GlossaryOrigem {
  MANUAL
  AI_GEMINI
  AI_OPENAI
  AI_ANTHROPIC
  AI_OPENROUTER
  AI_GROQ
  AI_DEEPSEEK
  CSV_IMPORT
}

// ── Indexação SEO ─────────────────────────────────────────────────────────────

model SeoIndexingLog {
  id         String   @id @default(cuid())
  url        String
  action     String   @default("URL_UPDATED")
  motor      String   // "google" | "indexnow"
  status     String   // "sent" | "error" | "skipped"
  statusCode Int?
  erro       String?
  origem     String?
  createdAt  DateTime @default(now())

  @@index([url])
  @@index([createdAt])
  @@index([motor, status])
}
